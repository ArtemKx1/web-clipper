{
  "manifest_version": 3,
  "name": "Web Clipper – Second Brain",
  "short_name": "Web Clipper",
  "version": "1.0.2",
  "description": "Your universal second brain for the web. Capture text, links, images with keyboard shortcuts.",
  "author": "Artem K.",
  "permissions": ["storage", "activeTab", "contextMenus", "sidePanel"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content-script.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "minimum_chrome_version": "114",
  "commands": {
    "_execute_side_panel": {
      "suggested_keys": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Open Web Clipper"
    },
    "capture": {
      "suggested_keys": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "Capture selection"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
